# Database Connection URL (e.g. PostgreSQL connection string)
DATABASE_URL="postgresql://username:password@localhost:5432/farmerapp?schema=public"

# Node Express Server Port
PORT=5000

# JSON Web Token Secret for Sign-In and Authorization
JWT_SECRET="replace-with-a-secure-random-secret-key"

# Secret Key required to sign up new Admin accounts
ADMIN_SIGNUP_SECRET="replace-with-a-secure-admin-passcode"

# AI Disease Detection Provider Keys (Optional: Falls back to smart Mock analysis if missing)
GEMINI_API_KEY=""

# Allowed Frontend URL(s) for CORS (supports comma-separated list for multiple domains)
FRONTEND_URL="http://localhost:3000"